Cell[BoxData[
 RowBox[{
  RowBox[{"plots", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Internal`DeactivateMessages", "[", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x", "=", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"#", "\[Equal]", 
            RowBox[{"1", "/", "100"}]}], ",", 
           RowBox[{"x", "=", ".15"}], ",", ".3"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ListPlot", "[", 
         RowBox[{
          RowBox[{"Join", "@@", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"SurfaceOfSection", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"Random", "[", 
                  RowBox[{"Real", ",", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "x"}], ",", "x"}], "}"}]}], "]"}], ",", 
                 "\[IndentingNewLine]", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"Random", "[", 
                    RowBox[{"Real", ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "x"}], ",", "x"}], "}"}]}], "]"}], ",", 
                   RowBox[{"Random", "[", 
                    RowBox[{"Real", ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "x"}], ",", "x"}], "}"}]}], "]"}]}], "}"}], 
                 ",", "#"}], "}"}], ",", "1000"}], "]"}], ",", 
             RowBox[{"{", "100", "}"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"PlotStyle", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"PointSize", "[", ".007", "]"}], ",", "Green"}], "}"}]}],
           ",", 
          RowBox[{"AspectRatio", "\[Rule]", "Automatic"}], ",", 
          RowBox[{"PlotLabel", "\[Rule]", 
           RowBox[{"TraditionalForm", "[", 
            RowBox[{
             RowBox[{"e", "\[Equal]", "#"}], "/.", 
             RowBox[{
              RowBox[{"Rational", "[", 
               RowBox[{"n_", ",", "d_"}], "]"}], "\[RuleDelayed]", 
              RowBox[{"InlineFraction", "[", 
               RowBox[{"n", ",", "d"}], "]"}]}]}], "]"}]}]}], "]"}]}], ")"}], 
      "]"}], "&"}], "/@", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"1", "/", "100"}], ",", 
      RowBox[{"1", "/", "12"}], ",", 
      RowBox[{"1", "/", "8"}]}], "}"}]}]}], "\n"}]], "Input",
