Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"V", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"1", "/", "2"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"x", "^", "2"}], "+", 
      RowBox[{"y", "^", "2"}], "+", 
      RowBox[{"2", " ", 
       RowBox[{"x", "^", "2"}], " ", "y"}], "-", 
      RowBox[{
       RowBox[{"2", "/", "3"}], " ", 
       RowBox[{"y", "^", "3"}]}]}], ")"}]}]}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"e", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x_", ",", "y_"}], "}"}], ",", "t_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     RowBox[{"x", "[", "t", "]"}], "^", "2"}], "+", 
    RowBox[{
     RowBox[{"y", "[", "t", "]"}], "^", "2"}], "+", 
    RowBox[{"2", " ", 
     RowBox[{
      RowBox[{"x", "[", "t", "]"}], "^", "2"}], " ", 
     RowBox[{"y", "[", "t", "]"}]}], "-", 
    RowBox[{
     RowBox[{"2", "/", "3"}], " ", 
     RowBox[{
      RowBox[{"y", "[", "t", "]"}], "^", "3"}]}], "+", 
    RowBox[{
     RowBox[{
      RowBox[{"x", "'"}], "[", "t", "]"}], "^", "2"}], "+", 
    RowBox[{
     RowBox[{
      RowBox[{"y", "'"}], "[", "t", "]"}], "^", "2"}]}], 
   ")"}]}], "\n"}], "Input",
