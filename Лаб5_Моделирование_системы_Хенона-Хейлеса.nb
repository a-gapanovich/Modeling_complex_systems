Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"HenonHeiles", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x0_", ",", 
      RowBox[{"{", 
       RowBox[{"y0_", ",", "dy0_"}], "}"}], ",", "e_"}], "}"}], ",", 
    "tmax_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"dx0", "=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"2", "/", "3"}], " ", 
          RowBox[{"y0", "^", "3"}]}], "+", 
         RowBox[{"2", " ", "e"}], "-", 
         RowBox[{"x0", "^", "2"}], "-", 
         RowBox[{"y0", "^", "2"}], "-", 
         RowBox[{"2", " ", 
          RowBox[{"x0", "^", "2"}], " ", "y0"}], "-", 
         RowBox[{"dy0", "^", "2"}]}], "]"}]}], ",", "x", ",", "y", ",", "t"}],
      "}"}], ",", 
    RowBox[{"Flatten", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}], "/.", 
      RowBox[{"NDSolve", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"x", "''"}], "[", "t", "]"}], "\[Equal]", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"x", "[", "t", "]"}]}], "-", 
            RowBox[{"2", " ", 
             RowBox[{"y", "[", "t", "]"}], " ", 
             RowBox[{"x", "[", "t", "]"}]}]}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"y", "''"}], "[", "t", "]"}], "\[Equal]", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"y", "[", "t", "]"}]}], "-", 
            RowBox[{
             RowBox[{"x", "[", "t", "]"}], "^", "2"}], "+", 
            RowBox[{
             RowBox[{"y", "[", "t", "]"}], "^", "2"}]}]}], ",", 
          RowBox[{
           RowBox[{"y", "[", "0", "]"}], "\[Equal]", "y0"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"y", "'"}], "[", "0", "]"}], "\[Equal]", "dy0"}], ",", 
          RowBox[{
           RowBox[{"x", "[", "0", "]"}], "\[Equal]", "x0"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"x", "'"}], "[", "0", "]"}], "\[Equal]", "dx0"}]}], "}"}],
         ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "y"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "0", ",", "tmax"}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Method", "\[Rule]", "ExplicitRungeKutta"}], ",", 
        RowBox[{"MaxSteps", "\[Rule]", "5000"}]}], "]"}]}], "]"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.7945730635474577`*^9, 3.794573063548437*^9}, {
  3.828623181847353*^9, 
  3.828623201657897*^9}},ExpressionUUID->"a7d9a8fe-9fcb-4f8c-af18-\
47737f7cc907"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SurfaceOfSection", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x0_", ",", 
      RowBox[{"{", 
       RowBox[{"y0_", ",", "dy0_"}], "}"}], ",", "e_"}], "}"}], ",", 
    "tmax_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"dx0", "=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"2", "/", "3"}], " ", 
          RowBox[{"y0", "^", "3"}]}], "+", 
         RowBox[{"2", " ", "e"}], "-", 
         RowBox[{"x0", "^", "2"}], "-", 
         RowBox[{"y0", "^", "2"}], "-", 
         RowBox[{"2", " ", 
          RowBox[{"x0", "^", "2"}], " ", "y0"}], "-", 
         RowBox[{"dy0", "^", "2"}]}], "]"}]}], ",", "x", ",", "y", ",", "t"}],
      "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"#", "\[Equal]", 
         RowBox[{"{", "}"}]}], ",", 
        RowBox[{"{", "}"}], ",", 
        RowBox[{"First", "[", "#", "]"}]}], "]"}], "&"}], "@", 
     RowBox[{"Last", "[", 
      RowBox[{"Reap", "[", 
       RowBox[{"NDSolve", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"x", "''"}], "[", "t", "]"}], "\[Equal]", 
            RowBox[{
             RowBox[{"-", 
              RowBox[{"x", "[", "t", "]"}]}], "-", 
             RowBox[{"2", " ", 
              RowBox[{"y", "[", "t", "]"}], " ", 
              RowBox[{"x", "[", "t", "]"}]}]}]}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"y", "''"}], "[", "t", "]"}], "\[Equal]", 
            RowBox[{
             RowBox[{"-", 
              RowBox[{"y", "[", "t", "]"}]}], "-", 
             RowBox[{
              RowBox[{"x", "[", "t", "]"}], "^", "2"}], "+", 
             RowBox[{
              RowBox[{"y", "[", "t", "]"}], "^", "2"}]}]}], ",", 
           RowBox[{
            RowBox[{"y", "[", "0", "]"}], "\[Equal]", "y0"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"y", "'"}], "[", "0", "]"}], "\[Equal]", "dy0"}], ",", 
           RowBox[{
            RowBox[{"x", "[", "0", "]"}], "\[Equal]", "x0"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"x", "'"}], "[", "0", "]"}], "\[Equal]", "dx0"}]}], 
          "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "0", ",", "tmax"}], "}"}], ",", 
         RowBox[{"Method", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{"EventLocator", ",", 
            RowBox[{"\"\<Event\>\"", "\[Rule]", 
             RowBox[{"x", "[", "t", "]"}]}], ",", 
            RowBox[{"\"\<EventAction\>\"", "\[RuleDelayed]", 
             RowBox[{"Sow", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"y", "[", "t", "]"}], ",", 
                RowBox[{
                 RowBox[{"y", "'"}], "[", "t", "]"}]}], "}"}], "]"}]}]}], 
           "}"}]}]}], "]"}], "]"}], "]"}]}]}], "]"}]}]], "Input",
