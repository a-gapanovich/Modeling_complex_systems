          RowBox[{
           RowBox[{"y", "'"}], "[", "x", "]"}]}]}], "\[Equal]", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "g"}], "*", 
          RowBox[{"Sin", "[", 
           RowBox[{"y", "[", "x", "]"}], "]"}]}], "+", 
         RowBox[{
          RowBox[{"F", "[", 
           RowBox[{"[", "3", "]"}], "]"}], 
          RowBox[{"Cos", "[", 
           RowBox[{"w", "*", "x"}], "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", "0.1"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "0", "]"}], "\[Equal]", "1"}]}], "}"}], ",",
      "y", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "100"}], "}"}]}], "]"}]}], 
