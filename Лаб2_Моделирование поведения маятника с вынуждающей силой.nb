Cell[BoxData[{
 RowBox[{
  RowBox[{"sol3", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"y", "''"}], "[", "x", "]"}], "+", 
         RowBox[{
          RowBox[{"gamma", "[", 
           RowBox[{"[", "2", "]"}], "]"}], 
          RowBox[{
           RowBox[{"y", "'"}], "[", "x", "]"}]}]}], "\[Equal]", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "g"}], "*", 
          RowBox[{"Sin", "[", 
           RowBox[{"y", "[", "x", "]"}], "]"}]}], "+", 
         RowBox[{
          RowBox[{"F", "[", 
           RowBox[{"[", "3", "]"}], "]"}], 
          RowBox[{"Cos", "[", 
           RowBox[{"w", "*", "x"}], "]"}]}]}]}], ",", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "==", "0"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "0", "]"}], "\[Equal]", "1"}]}], "}"}], ",",
      "y", ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "100"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sol3dx", "=", 
