Cell[BoxData[{
 RowBox[{
  RowBox[{"n", "=", "1000."}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tmax", "=", 
   RowBox[{"10.", "*", "n"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.7968371459142833`*^9, 3.7968372437722683`*^9}, {
  3.7968374487638054`*^9, 3.796837450047369*^9}, {3.7968377080450172`*^9, 
