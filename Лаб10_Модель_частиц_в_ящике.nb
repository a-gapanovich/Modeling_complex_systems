Cell[BoxData[{
 RowBox[{
  RowBox[{"nl", "=", "n"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nllist", "=", 
   RowBox[{"{", "nl", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"itime", "=", "1"}], ",", 
   RowBox[{"itime", "\[LessEqual]", "tmax"}], ",", 
   RowBox[{"itime", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"prob", "=", 
     RowBox[{"nl", "/", "n"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"rnd", "=", 
     RowBox[{"RandomReal", "[", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"rnd", "\[LessEqual]", "prob"}], ",", 
      RowBox[{"nl", "=", 
       RowBox[{"nl", "-", "1"}]}], ",", 
      RowBox[{"nl", "=", 
       RowBox[{"nl", "+", "1"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"nllist", ",", "nl"}], "]"}]}]}], "\[IndentingNewLine]", 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"ListLinePlot", "[", "nllist", "]"}]}], "Input",
