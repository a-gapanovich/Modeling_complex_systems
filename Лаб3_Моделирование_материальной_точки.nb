Cell[BoxData[{
 RowBox[{
  RowBox[{"n", "=", "5000"}], ";", " ", 
  RowBox[{"dx", "=", "0.001"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x", "=", "0"}], ";", " ", 
  RowBox[{"y", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xyVector", "=", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vxVector", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vyVector", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vx", "=", "vx0"}], ";", " ", 
  RowBox[{"vy", "=", "vy0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", "0"}], ",", 
   RowBox[{"i", "\[LessEqual]", "n"}], ",", 
   RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vxTMP", "=", "vx"}], ";", "\[IndentingNewLine]", 
    RowBox[{"vyTMP", "=", 
     RowBox[{"vy", "-", 
      RowBox[{"g", "*", "dx"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"xTMP", "=", 
     RowBox[{"x", "+", 
      RowBox[{"vxTMP", "*", "dx"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"yTMP", "=", 
     RowBox[{"y", "+", 
      RowBox[{"vyTMP", "*", "dx"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"border", "[", "xTMP", "]"}], ">", "yTMP"}], ",", 
      RowBox[{"vyTMP", "=", 
       RowBox[{"-", "vyTMP"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"x", "=", "xTMP"}], ";", "\[IndentingNewLine]", 
    RowBox[{"y", "=", "yTMP"}], ";", "\[IndentingNewLine]", 
    RowBox[{"vx", "=", "vxTMP"}], ";", "\[IndentingNewLine]", 
    RowBox[{"vy", "=", "vyTMP"}], ";", "\[IndentingNewLine]", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"xyVector", ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}]}], "]"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.795170143628209*^9, 3.7951701860244637`*^9}, {
