Notebook[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"L", " ", "=", " ", 
   RowBox[{"Sqrt", "[", "2", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"h", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"a", " ", "=", " ", 
    RowBox[{"Pi", "/", "L"}]}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Pr", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Rl", "=", "30"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "=", 
   RowBox[{"4", "*", 
    RowBox[{
     RowBox[{"Pi", "^", "2"}], "/", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"a", "^", "2"}], "+", 
       RowBox[{"Pi", "^", "2"}]}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"endTime", "=", "50"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"coeff1", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"a", "^", "2"}], "+", 
        RowBox[{"Pi", "^", "2"}]}], ")"}], "*", 
      RowBox[{"Sqrt", "[", "2", "]"}]}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{"a", "*", "Pi"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"solution", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{"Pr", "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"y", "[", "t", "]"}], "-", 
           RowBox[{"x", "[", "t", "]"}]}], ")"}]}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{"Rl", "*", 
          RowBox[{"x", "[", "t", "]"}]}], "-", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], " ", 
          RowBox[{"z", "[", "t", "]"}]}], "-", 
         RowBox[{"y", "[", "t", "]"}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"z", "'"}], "[", "t", "]"}], "\[Equal]", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], " ", 
          RowBox[{"y", "[", "t", "]"}]}], "-", 
         RowBox[{"b", "*", " ", 
          RowBox[{"z", "[", "t", "]"}]}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"x", "[", "0", "]"}], "\[Equal]", 
        RowBox[{"z", "[", "0", "]"}], "\[Equal]", "1"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"y", "[", "0", "]"}], "\[Equal]", "0"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y", ",", "z"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "endTime"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Psi", "[", 
    RowBox[{"wx_", ",", "wz_", ",", "t_"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"coeff1", "*", 
       RowBox[{"x", "[", "t", "]"}]}], "/.", "solution"}], ")"}], "*", 
    RowBox[{"Sin", "[", 
     RowBox[{"Pi", "*", "wz"}], "]"}], "*", 
    RowBox[{"Sin", "[", 
     RowBox[{"a", "*", "wx"}], "]"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{
  3.794216431205665*^9, {3.828582288288063*^9, 3.8285823250271096`*^9}, {
   3.8285823856451902`*^9, 3.828582386959611*^9}, {3.828582621406886*^9, 
   3.828582663775169*^9}, {3.828582704857383*^9, 3.8285827062521935`*^9}, {
   3.8285828735943108`*^9, 3.8285828895876904`*^9}, {3.82858292441504*^9, 
   3.828582927499967*^9}, {3.828582974734559*^9, 3.8285830038885283`*^9}, {
   3.8285830585318556`*^9, 3.8285830598267*^9}, {3.8286279388367405`*^9, 
   3.828627945501623*^9}},ExpressionUUID->"ea926cfc-d2b8-4a31-8d98-\
b259385dbd12"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ParametricPlot3D", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Evaluate", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x", "[", "t", "]"}], ",", 
        RowBox[{"y", "[", "t", "]"}], ",", 
        RowBox[{"z", "[", "t", "]"}]}], "}"}], "/.", "solution"}], "]"}], ",",
     "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "50"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotPoints", "\[Rule]", "5000"}]}], "\[IndentingNewLine]", "]"}],
   "\n"}]], "Input",
 CellChangeTimes->{{3.828582302528386*^9, 3.8285823148306093`*^9}, 
   3.828582649252491*^9, {3.82862794931481*^9, 
